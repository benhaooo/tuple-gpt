{
  "name": "tuple-gpt",
  "version": "1.0.0",
  "description": "Tuple GPT Monorepo",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @tuple-gpt/web dev",
    "dev:extension": "pnpm --filter @tuple-gpt/extension dev",
    "build:all": "pnpm -r build",
    "build:web": "pnpm --filter @tuple-gpt/web build",
    "build:extension": "pnpm --filter @tuple-gpt/extension build",
    "type-check": "pnpm -r type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fix": "pnpm lint:fix && pnpm format",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.13.14",
    "@types/uuid": "^10.0.0",
    "@unocss/reset": "^66.5.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "less": "^4.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "reka-ui": "^2.8.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.0",
    "unocss": "^66.5.10",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-shadcn": "^1.0.1",
    "unplugin-auto-import": "^20.0.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.4"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash": "^4.17.23",
    "lucide-vue-next": "^0.575.0",
    "marked": "^15.0.12",
    "pinia": "^3.0.3",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.1.0",
    "vue": "^3.5.13",
    "vue-toast-notification": "^3.1.3"
  }
}
